---
import info from '../data/info.json';

const { personal, education, languages } = info;
---

<section id="about" class="py-20 bg-dark-light/50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16 reveal">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4">
        Sobre <span class="gradient-text">mí</span>
      </h2>
      <p class="text-gray-400 max-w-2xl mx-auto">
        Conóceme un poco más allá del código
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Photo/Illustration -->
      <div class="reveal">
        <div class="relative">
          <!-- Background decoration -->
          <div class="absolute -inset-4 bg-gradient-to-br from-primary/20 to-secondary/20 rounded-2xl blur-xl"></div>

          <!-- Card -->
          <div class="relative glass rounded-2xl p-8">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-16 h-16 rounded-full bg-gradient-to-br from-primary to-secondary flex items-center justify-center text-3xl">
                👨‍💻
              </div>
              <div>
                <h3 class="text-xl font-bold text-light">{personal.fullName}</h3>
                <p class="text-primary">{personal.title}</p>
              </div>
            </div>

            <p class="text-gray-300 leading-relaxed mb-6">
              {personal.bio}
            </p>

            <!-- Quick Info -->
            <div class="grid grid-cols-2 gap-4">
              <div class="flex items-center gap-2 text-gray-400">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                <span>{personal.location}</span>
              </div>
              <div class="flex items-center gap-2 text-gray-400">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
                <span class="truncate">{personal.email}</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Info Cards -->
      <div class="space-y-6">
        <!-- Education -->
        <div class="reveal glass rounded-xl p-6 card-hover">
          <div class="flex items-start gap-4">
            <div class="p-3 bg-primary/20 rounded-lg">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path d="M12 14l9-5-9-5-9 5 9 5z"/>
                <path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222"/>
              </svg>
            </div>
            <div>
              <h4 class="text-lg font-semibold text-light mb-1">Educación</h4>
              {education.map(edu => (
                <div class="mb-2">
                  <p class="text-primary font-medium">{edu.title}</p>
                  <p class="text-gray-400 text-sm">{edu.institution} • {edu.period}</p>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Languages -->
        <div class="reveal glass rounded-xl p-6 card-hover">
          <div class="flex items-start gap-4">
            <div class="p-3 bg-secondary/20 rounded-lg">
              <svg class="w-6 h-6 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"/>
              </svg>
            </div>
            <div class="flex-1">
              <h4 class="text-lg font-semibold text-light mb-3">Idiomas</h4>
              <div class="flex flex-wrap gap-2">
                {languages.map(lang => (
                  <span class="px-3 py-1 bg-dark-light text-gray-300 rounded-full text-sm">
                    {lang.name} <span class="text-gray-500">({lang.level})</span>
                  </span>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- Fun Facts / Values -->
        <div class="reveal glass rounded-xl p-6 card-hover">
          <div class="flex items-start gap-4">
            <div class="p-3 bg-green-500/20 rounded-lg">
              <svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
            </div>
            <div>
              <h4 class="text-lg font-semibold text-light mb-2">Lo que me motiva</h4>
              <ul class="text-gray-400 space-y-1 text-sm">
                <li class="flex items-center gap-2">
                  <span class="text-primary">▸</span> Aprender tecnologías nuevas constantemente
                </li>
                <li class="flex items-center gap-2">
                  <span class="text-primary">▸</span> Escribir código limpio y mantenible
                </li>
                <li class="flex items-center gap-2">
                  <span class="text-primary">▸</span> Resolver problemas complejos con soluciones simples
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
