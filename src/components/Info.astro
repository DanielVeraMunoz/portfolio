---
import info from '../data/info.json';

const { education, languages } = info;
---

<section id="info" class="py-20">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-12 reveal">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4">
        Información adicional
      </h2>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      <!-- Education -->
      <div class="reveal glass rounded-2xl p-6 card-hover">
        <div class="flex items-center gap-3 mb-6">
          <div class="p-3 bg-primary/20 rounded-lg">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path d="M12 14l9-5-9-5-9 5 9 5z"/>
              <path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-light">Formación</h3>
        </div>

        {education.map(edu => (
          <div class="mb-4 last:mb-0">
            <h4 class="text-primary font-semibold">{edu.title}</h4>
            <p class="text-gray-300">{edu.institution}</p>
            <p class="text-gray-500 text-sm">{edu.period}</p>
            <p class="text-gray-400 text-sm mt-2">{edu.description}</p>
          </div>
        ))}
      </div>

      <!-- Languages -->
      <div class="reveal glass rounded-2xl p-6 card-hover">
        <div class="flex items-center gap-3 mb-6">
          <div class="p-3 bg-secondary/20 rounded-lg">
            <svg class="w-6 h-6 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-light">Idiomas</h3>
        </div>

        <div class="space-y-4">
          {languages.map(lang => (
            <div class="flex items-center justify-between">
              <span class="text-gray-300 font-medium">{lang.name}</span>
              <span class="px-3 py-1 bg-dark text-gray-400 rounded-full text-sm">
                {lang.level}
              </span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
