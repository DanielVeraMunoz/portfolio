---
import info from '../data/info.json';

const { personal } = info;
---

<section id="contact" class="py-20 bg-dark-light/50">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="reveal glass rounded-2xl p-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4">
        <span class="gradient-text">Hablemos</span>
      </h2>

      <p class="text-gray-400 mb-8 max-w-lg mx-auto">
        Estoy abierto a oportunidades de trabajo, colaboraciones o simplemente charlar sobre tecnología.
      </p>

      <!-- Contact Form -->
      <form
        action="https://formspree.io/f/xreoyolj"
        method="POST"
        class="space-y-4 text-left"
      >
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label for="name" class="block text-gray-400 text-sm mb-2">Nombre</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-3 bg-dark border border-gray/30 rounded-lg text-light placeholder-gray-500 focus:outline-none focus:border-primary transition-colors"
              placeholder="Tu nombre"
            />
          </div>
          <div>
            <label for="email" class="block text-gray-400 text-sm mb-2">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 bg-dark border border-gray/30 rounded-lg text-light placeholder-gray-500 focus:outline-none focus:border-primary transition-colors"
              placeholder="tu@email.com"
            />
          </div>
        </div>

        <div>
          <label for="message" class="block text-gray-400 text-sm mb-2">Mensaje</label>
          <textarea
            id="message"
            name="message"
            rows="4"
            required
            class="w-full px-4 py-3 bg-dark border border-gray/30 rounded-lg text-light placeholder-gray-500 focus:outline-none focus:border-primary transition-colors resize-none"
            placeholder="Cuéntame sobre tu proyecto o idea..."
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full px-6 py-3 bg-primary hover:bg-primary-dark text-white font-medium rounded-lg transition-all hover:scale-[1.02] flex items-center justify-center gap-2"
        >
          Enviar mensaje
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
          </svg>
        </button>
      </form>

      <p class="text-gray-500 text-sm mt-6">
        O escríbeme directamente a <a href="mailto:{personal.email}" class="text-primary hover:underline">{personal.email}</a>
      </p>
    </div>
  </div>
</section>
